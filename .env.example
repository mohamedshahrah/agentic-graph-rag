# ------------------------------------------------------------------------------
# Copy to `.env` and fill in what you use. Nothing here is required for the
# `local` profile except the service URLs (which already default to Docker).
# ------------------------------------------------------------------------------

# Which config profile to load:
#   production  the VPS deployment: accounts + limits ON, Gemini/DeepSeek/Qwen
#               chat, Cohere embeddings + rerank, DuckDB vectors
#   api         cloud providers (Anthropic/Voyage/Gemini), auth OFF
#   local       Ollama + open models, everything on your machine, auth OFF
#
# WARNING: `local` and `api` disable authentication — any caller can act as any
# user via the X-User-Id header. They are development profiles. Anything
# reachable from a network wants `production`.
GRAPHRAG_PROFILE=production

# --- Infrastructure (defaults match docker-compose) ---------------------------
GRAPHRAG_NEO4J_URI=bolt://localhost:7687
GRAPHRAG_NEO4J_USER=neo4j
GRAPHRAG_NEO4J_PASSWORD=please-change-me
GRAPHRAG_REDIS_URL=redis://localhost:6379/0

# Postgres: accounts, limits, usage, chat history, and (with
# agent.memory_backend=postgres) durable agent memory. Required by the
# `production` profile.
GRAPHRAG_DATABASE_URL=postgresql+asyncpg://graphrag:change-me@localhost:5432/graphrag
GRAPHRAG_POSTGRES_PASSWORD=change-me

# --- Local runtime (Ollama) ---------------------------------------------------
GRAPHRAG_OLLAMA_BASE_URL=http://localhost:11434
# Inside Docker the containers default to the Ollama on your host
# (host.docker.internal). To use the bundled service instead
# (docker compose --profile local up), point them at it:
# GRAPHRAG_OLLAMA_BASE_URL_INTERNAL=http://ollama:11434
GRAPHRAG_OLLAMA_BASE_URL_INTERNAL=

# --- Auth & accounts ----------------------------------------------------------
# Break-glass admin key (header X-Admin-Key). Works even with no admin account.
GRAPHRAG_ADMIN_KEY=
# This account is promoted to admin at startup if it exists — sign up with it
# first, then restart, and you own the admin panel.
GRAPHRAG_ADMIN_EMAIL=

# Verification / OTP email delivery. Set exactly one provider key; with neither,
# codes are logged to the server console (fine for dev, useless in production).
GRAPHRAG_EMAIL_FROM=GraphRAG <noreply@yourdomain.com>
RESEND_API_KEY=
BREVO_API_KEY=

# --- API keys (only for the providers you actually enable) --------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=          # Gemini chat + OCR (production profile)
COHERE_API_KEY=          # embed-v4.0 + rerank-v4.0-fast (production profile)
DEEPSEEK_API_KEY=        # deepseek-v4-flash
DASHSCOPE_API_KEY=       # Qwen via DashScope
VOYAGE_API_KEY=

# --- Uploads ------------------------------------------------------------------
# The frontend's nginx rejects bodies larger than this before they reach the API.
# Keep it >= api.max_upload_mb in configs/*.yaml (nginx's own default is 1 MB).
MAX_UPLOAD_MB=25

# --- Resource controls (per-container RAM / CPU caps) -------------------------
# Tune these to your machine. Memory as e.g. 4g/512m; CPU as a number of cores.
# The defaults below target a 2 vCPU / 8 GB VPS and sum to ~4.7 GB, leaving
# headroom for the OS and page cache. Raise them on a bigger box.
API_MEM_LIMIT=2g
API_CPU_LIMIT=2
NEO4J_MEM_LIMIT=1536m
NEO4J_CPU_LIMIT=1
NEO4J_HEAP=640m
NEO4J_PAGECACHE=320M
POSTGRES_MEM_LIMIT=768m
POSTGRES_CPU_LIMIT=1
REDIS_MEM_LIMIT=256m
REDIS_MAXMEMORY=192mb
FRONTEND_MEM_LIMIT=64m
# Only used with `--profile worker` (separate ingest process; incompatible with
# the duckdb vector provider, which requires single-process ownership).
WORKER_MEM_LIMIT=1g
WORKER_CPU_LIMIT=1
OLLAMA_MEM_LIMIT=8g
OLLAMA_CPU_LIMIT=4

# Concurrency / CPU-thread caps
GRAPHRAG_USE_WORKER=0           # 1 = dispatch ingest to the arq worker service
GRAPHRAG_WORKER_CONCURRENCY=2   # parallel ingest jobs per worker
OMP_NUM_THREADS=2               # CPU threads for local model math

# --- Reverse proxy / TLS (the `proxy` service) -------------------------------
# :80            plain HTTP (default)
# localhost      HTTPS via Caddy's local self-signed CA
# rag.example.com  HTTPS via automatic Let's Encrypt (set TLS_EMAIL)
SITE_ADDRESS=:80
TLS_EMAIL=
PROXY_MEM_LIMIT=128m
PROXY_CPU_LIMIT=0.5
