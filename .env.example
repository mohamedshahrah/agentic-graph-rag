# ------------------------------------------------------------------------------
# Copy to `.env` and fill in what you use. Nothing here is required for the
# `local` profile except the service URLs (which already default to Docker).
# ------------------------------------------------------------------------------

# Which config profile to load: `local` (Ollama + open models) or `api` (cloud).
GRAPHRAG_PROFILE=api

# --- Infrastructure (defaults match docker-compose) ---------------------------
GRAPHRAG_NEO4J_URI=bolt://localhost:7687
GRAPHRAG_NEO4J_USER=neo4j
GRAPHRAG_NEO4J_PASSWORD=please-change-me
GRAPHRAG_REDIS_URL=redis://localhost:6379/0

# --- Local runtime (Ollama) ---------------------------------------------------
GRAPHRAG_OLLAMA_BASE_URL=http://localhost:11434
# Inside Docker the containers default to the Ollama on your host
# (host.docker.internal). To use the bundled service instead
# (docker compose --profile local up), point them at it:
# GRAPHRAG_OLLAMA_BASE_URL_INTERNAL=http://ollama:11434
GRAPHRAG_OLLAMA_BASE_URL_INTERNAL=

# --- Auth (only when auth.enabled=true) ---------------------------------------
# If set, this key is required (header X-Admin-Key) to create users.
GRAPHRAG_ADMIN_KEY=

# --- API keys (only for the providers you actually enable) --------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# --- Uploads ------------------------------------------------------------------
# The frontend's nginx rejects bodies larger than this before they reach the API.
# Keep it >= api.max_upload_mb in configs/*.yaml (nginx's own default is 1 MB).
MAX_UPLOAD_MB=25

# --- Resource controls (per-container RAM / CPU caps) -------------------------
# Tune these to your machine. Memory as e.g. 4g/512m; CPU as a number of cores.
API_MEM_LIMIT=4g
API_CPU_LIMIT=2
WORKER_MEM_LIMIT=4g
WORKER_CPU_LIMIT=2
NEO4J_MEM_LIMIT=2g
NEO4J_CPU_LIMIT=1.5
NEO4J_HEAP=1G
NEO4J_PAGECACHE=512M
REDIS_MEM_LIMIT=512m
REDIS_MAXMEMORY=384mb
FRONTEND_MEM_LIMIT=128m
OLLAMA_MEM_LIMIT=8g
OLLAMA_CPU_LIMIT=4

# Concurrency / CPU-thread caps
GRAPHRAG_WORKER_CONCURRENCY=2   # parallel ingest jobs per worker
OMP_NUM_THREADS=2               # CPU threads for local model math

# --- Reverse proxy / TLS (the `proxy` service) -------------------------------
# :80            plain HTTP (default)
# localhost      HTTPS via Caddy's local self-signed CA
# rag.example.com  HTTPS via automatic Let's Encrypt (set TLS_EMAIL)
SITE_ADDRESS=:80
TLS_EMAIL=
PROXY_MEM_LIMIT=128m
PROXY_CPU_LIMIT=0.5
