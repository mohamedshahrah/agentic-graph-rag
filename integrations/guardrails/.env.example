# ════════════════════════════════════════════════════════════════════════════
#  Guardrails Server — environment configuration
# ════════════════════════════════════════════════════════════════════════════
#  HOW TO USE:  copy this file to `.env`  (cp .env.example .env)  then edit it.
#  The server reads `.env` automatically at startup. Every var is GUARD_ + the
#  setting name. This file is the ONLY place model/provider/key live — everything
#  about *behavior* (what to detect, thresholds) lives in policies/*.yaml instead.
#
#  Pick ONE recipe below, uncomment it, done.
# ════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
#  1) THE MODEL  (this is the part you set in .env)
# ─────────────────────────────────────────────────────────────────────────────
# Preset options: anthropic | openai | gemini | deepseek | qwen | groq |
#                 together | ollama | vllm | custom | mock

# ── Recipe A: offline, no key (default — great for trying it out) ─────────────
GUARD_LLM_PROVIDER=mock

# ── Recipe B: Claude (Anthropic) ─────────────────────────────────────────────
# GUARD_LLM_PROVIDER=anthropic
# GUARD_LLM_API_KEY=sk-ant-...            # or export ANTHROPIC_API_KEY instead
# GUARD_LLM_MODEL=claude-opus-4-8         # optional; this is the preset default

# ── Recipe C: OpenAI ─────────────────────────────────────────────────────────
# GUARD_LLM_PROVIDER=openai
# GUARD_LLM_API_KEY=sk-...                # or export OPENAI_API_KEY instead
# GUARD_LLM_MODEL=gpt-4o-mini             # REQUIRED (openai preset has no default)

# ── Recipe D: local & free with Ollama ───────────────────────────────────────
#   1. install Ollama, then:   ollama pull llama3.1
#   2. uncomment the two lines below. No API key needed.
# GUARD_LLM_PROVIDER=ollama
# GUARD_LLM_MODEL=llama3.1                 # must match what you `ollama pull`ed

# ── Advanced model knobs (rarely needed) ─────────────────────────────────────
# GUARD_LLM_API_KEY=                       # overrides the preset's native key env var
# GUARD_LLM_BASE_URL=                      # override endpoint; REQUIRED for `custom`
GUARD_LLM_TIMEOUT_S=10.0                    # per judge call
GUARD_LLM_MAX_TOKENS=1024                   # judge response cap


# ─────────────────────────────────────────────────────────────────────────────
#  2) THE SERVER  (where it listens, whether it's locked down)
# ─────────────────────────────────────────────────────────────────────────────
# Loopback only by default (127.0.0.1): reachable from THIS machine, never the network.
# The code default already does this — leave it commented. Uncomment with 0.0.0.0 only to
# expose on the network. (Don't force 127.0.0.1 when using --env-file with Docker, or the
# container's own 0.0.0.0 gets overridden and `-p` can't reach it.)
# GUARD_HOST=0.0.0.0
GUARD_PORT=8080

# Interactive API docs at /docs, /redoc, /openapi.json. Off = the server exposes
# nothing but its endpoints. Set true only for local exploration.
GUARD_ENABLE_DOCS=false

# If set, every /v1/* call must send  Authorization: Bearer <key>  or  X-API-Key: <key>.
# /health is always exempt. Leave blank for no auth (fine on loopback).
# GUARD_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  3) BEHAVIOR DEFAULTS  (fine-grained detection lives in policies/*.yaml)
# ─────────────────────────────────────────────────────────────────────────────
# What to do when the judge is unreachable: open (rules only) | closed (block) | flag
GUARD_FAIL_MODE=flag

# Where policy YAML files load from, and which one is the default.
GUARD_POLICY_DIR=./policies
GUARD_DEFAULT_POLICY=default

# Verdict cache (identical requests reuse the judge result).
GUARD_CACHE_ENABLED=true
GUARD_CACHE_SIZE=2048
GUARD_CACHE_TTL_S=300

# Max concurrent in-flight judge calls (back-pressure).
GUARD_MAX_CONCURRENT_JUDGE=16

# Logging. Raw input text is OFF by default — only sha256 hashes are logged.
GUARD_LOG_LEVEL=info
GUARD_LOG_VERDICTS=true
GUARD_LOG_INPUTS=false
