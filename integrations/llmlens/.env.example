# Copy to `.env`. Defaults match docker-compose; override for your setup.

LLMLENS_PROFILE=default          # default | local

# --- Storage / infra (defaults match docker-compose) --------------------------
LLMLENS_CLICKHOUSE_HOST=localhost
LLMLENS_CLICKHOUSE_PORT=8123
LLMLENS_CLICKHOUSE_USER=default
LLMLENS_CLICKHOUSE_PASSWORD=
LLMLENS_CLICKHOUSE_DB=llmlens
LLMLENS_POSTGRES_DSN=postgresql://llmlens:please-change-me@localhost:5432/llmlens
LLMLENS_REDIS_URL=redis://localhost:6379/0

# --- Auth ---------------------------------------------------------------------
# Admin key gates project/user creation and the dashboard. Change it.
LLMLENS_ADMIN_KEY=change-me-admin

# --- Reverse proxy / TLS (the `proxy` service) --------------------------------
SITE_ADDRESS=:80                 # localhost or a domain enables HTTPS (Caddy)

# --- Resource caps (per container) --------------------------------------------
CLICKHOUSE_MEM_LIMIT=2g
CLICKHOUSE_CPU_LIMIT=2
POSTGRES_MEM_LIMIT=512m
REDIS_MEM_LIMIT=384m
API_MEM_LIMIT=1g
API_CPU_LIMIT=1
WORKER_MEM_LIMIT=1g
WORKER_CPU_LIMIT=1
DASHBOARD_MEM_LIMIT=128m
PROXY_MEM_LIMIT=128m
